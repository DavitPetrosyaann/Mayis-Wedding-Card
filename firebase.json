{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/p/**",
        "function": "projectPreviewPage"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      }
    ],
    "cleanUrls": false,
    "trailingSlash": false
  },
  "auth": {
    "providers": {
      "emailPassword": true,
      "phone": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "PreZento",
        "supportEmail": "vahanhekimyan99@gmail.com",
        "authorizedRedirectUris": [
          "https://prezento-am.web.app",
          "https://prezento-am.firebaseapp.com",
          "http://localhost:5173",
          "http://localhost:4173"
        ]
      }
    }
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  }
}